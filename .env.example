# ==================== 数据库配置 ====================
# PostgreSQL 数据库密码
DB_PASSWORD=123456

# Redis 密码（如果不需要密码认证，留空即可）
REDIS_PASSWORD=

# Neo4j 密码
NEO4J_PASSWORD=memory123

# RabbitMQ 配置
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ==================== MinIO 配置 ====================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ==================== API 密钥配置 ====================
# OpenAI API 密钥（阿里云 DashScope）
OPENAI_API_KEY=your_openai_api_key_here

# 博查 API 密钥
BOCHA_API_KEY=your_bocha_api_key_here

# ==================== 其他配置 ====================
# 日志级别
LOG_LEVEL=INFO

# JVM 内存配置
JVM_XMS=512m
JVM_XMX=1g
